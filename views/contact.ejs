<%- include('partials/header') %>

<section class="about-hero">
  <div class="hero-content">
    <h1>Contact Cool Cruze</h1>
    <p>We're here to help — reach out to us anytime</p>
  </div>
</section>

<div class="about-content">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;">
    <div>
      <h2>Get In Touch</h2>
      <p>Have questions about our AC rentals? Want to know more about pricing or availability? We'd love to hear from you.</p>

      <div style="display:flex;flex-direction:column;gap:20px;margin-top:24px;">
        <div style="display:flex;align-items:center;gap:16px;padding:16px 20px;background:#f8fafc;border-radius:12px;">
          <span style="font-size:24px;">📞</span>
          <div>
            <div style="font-size:13px;color:var(--text-light);">Call or WhatsApp</div>
            <a href="tel:+<%= whatsappNumber %>" style="font-size:18px;font-weight:700;color:var(--primary);text-decoration:none;">+<%= whatsappNumber %></a>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:16px;padding:16px 20px;background:#f8fafc;border-radius:12px;">
          <span style="font-size:24px;">✉️</span>
          <div>
            <div style="font-size:13px;color:var(--text-light);">Email</div>
            <a href="mailto:info@coolcruze.in" style="font-size:18px;font-weight:700;color:var(--primary);text-decoration:none;">info@coolcruze.in</a>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:16px;padding:16px 20px;background:#f8fafc;border-radius:12px;">
          <span style="font-size:24px;">📍</span>
          <div>
            <div style="font-size:13px;color:var(--text-light);">Service Area</div>
            <div style="font-size:18px;font-weight:700;">Mumbai, India</div>
          </div>
        </div>
      </div>

      <a href="https://wa.me/<%= whatsappNumber %>" target="_blank" style="display:inline-flex;align-items:center;gap:8px;margin-top:24px;padding:14px 32px;background:#25d366;color:white;border-radius:50px;font-weight:700;font-size:16px;text-decoration:none;">Chat on WhatsApp</a>
    </div>

    <div>
      <h2>Send Us a Message</h2>
      <form id="contactForm" style="display:flex;flex-direction:column;gap:16px;margin-top:16px;">
        <input type="text" id="contactName" placeholder="Your Name *" required style="padding:14px 16px;border:1px solid #e2e8f0;border-radius:10px;font-size:15px;width:100%;">
        <input type="tel" id="contactPhone" placeholder="Phone Number *" required style="padding:14px 16px;border:1px solid #e2e8f0;border-radius:10px;font-size:15px;width:100%;">
        <input type="email" id="contactEmail" placeholder="Email (Optional)" style="padding:14px 16px;border:1px solid #e2e8f0;border-radius:10px;font-size:15px;width:100%;">
        <textarea id="contactMsg" placeholder="Your Message *" required rows="4" style="padding:14px 16px;border:1px solid #e2e8f0;border-radius:10px;font-size:15px;width:100%;resize:vertical;"></textarea>
        <button type="submit" id="contactSubmitBtn" style="padding:14px 32px;background:var(--primary);color:white;border:none;border-radius:50px;font-weight:700;font-size:16px;cursor:pointer;">Send Message</button>
      </form>
      <div id="contactSuccess" style="display:none;text-align:center;padding:32px;background:#f0fdf4;border-radius:12px;margin-top:16px;">
        <div style="font-size:48px;margin-bottom:12px;">✅</div>
        <h3 style="margin-bottom:4px;">Message Sent!</h3>
        <p style="color:var(--text-light);">We'll get back to you shortly.</p>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById('contactForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('contactSubmitBtn');
  btn.disabled = true;
  btn.textContent = 'Sending...';
  const data = {
    name: document.getElementById('contactName').value.trim(),
    phone: document.getElementById('contactPhone').value.trim(),
    email: document.getElementById('contactEmail').value.trim(),
    message: document.getElementById('contactMsg').value.trim()
  };
  if (!data.name || !data.phone || !data.message) {
    btn.disabled = false;
    btn.textContent = 'Send Message';
    return;
  }
  try {
    const params = new URLSearchParams(data);
    const res = await fetch('/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: params.toString()
    });
    const result = await res.json();
    if (result.success) {
      this.style.display = 'none';
      document.getElementById('contactSuccess').style.display = 'block';
    }
  } catch(e) {
    btn.disabled = false;
    btn.textContent = 'Send Message';
  }
});
</script>

<%- include('partials/footer') %>