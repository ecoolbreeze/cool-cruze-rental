<%- include('partials/header') %>

<section class="hero">
  <div class="hero-slideshow">
    <img class="hero-slide active" src="/uploads/hero.png" alt="Hero">
    <img class="hero-slide" src="/uploads/hero-1.png" alt="Hero 1">
    <img class="hero-slide" src="/uploads/hero-2.png" alt="Hero 2">
    <img class="hero-slide full-bleed" src="/uploads/hero-3.png" alt="Hero 3">
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <h1>Stay Cool with Cool Cruze</h1>
    <p>Premium Tower AC Rentals  Affordable, Reliable, and Delivered to your Doorstep.</p>
    <div class="hero-buttons">
      <a href="/products" class="btn btn-primary">Browse Products</a>
      <a href="/about" class="btn btn-outline">Learn More</a>
    </div>
  </div>
</section>

<% if (featured && featured.length > 0) { %>
<section class="section">
  <div class="section-title">
    <h2>Featured Products</h2>
    <div class="accent-line"></div>
    <p>Our most popular AC units available for rent</p>
  </div>
  <div class="carousel-wrap">
    <div class="carousel-track" id="featuredCarousel">
      <% for (let i = 0; i < 2; i++) { %>
        <% featured.forEach(product => { %>
        <div class="carousel-card">
          <% const img = product.featured_image || product.card_image || (product.images && product.images.length ? product.images[0] : product.image); %>
          <div class="carousel-img" style="<%= img ? 'background-image:url('+img+')' : '' %>">
            <% if (!img) { %>❄️<% } %>
          </div>
          <div class="carousel-body">
            <div class="product-brand"><%= product.brand %></div>
            <div class="product-name"><%= product.name %></div>
            <div class="product-specs">
              <span class="product-spec"><%= product.capacity %></span>
              <span class="product-spec"><%= product.type %></span>
            </div>
            <div class="product-price"><%= product.tiers && product.tiers.length ? 'From ' : '' %>₹<%= Number(product.monthly_price).toLocaleString() %> <span>/day</span></div>
            <div class="product-actions" style="margin-top:auto;">
              <button onclick="openRentModal(<%= product.id %>, '<%= product.name.replace(/'/g, "\\'") %>', '<%= product.brand.replace(/'/g, "\\'") %>', '<%= product.capacity %>', <%= product.monthly_price %>)" class="btn-rent">Rent Now</button>
              <a href="/product/<%= product.id %>" class="btn-details">Details</a>
            </div>
          </div>
        </div>
        <% }) %>
      <% } %>
    </div>
    <button class="carousel-btn carousel-prev" onclick="moveSlide(-1)">‹</button>
    <button class="carousel-btn carousel-next" onclick="moveSlide(1)">›</button>
    <div class="carousel-dots" id="carouselDots"></div>
  </div>
</section>
<% } %>

