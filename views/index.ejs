    gap: 12px;
    max-width: 300px;
  }

  .step-connector {
    transform: rotate(90deg);
    padding: 4px 0;
  }

  .testimonials-grid {
    grid-template-columns: 1fr;
    max-width: 400px;
  }
}

@media (max-width: 500px) {
  .benefits-grid-2col {
    grid-template-columns: 1fr;
    max-width: 260px;
