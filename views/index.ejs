<script>
function toggleFaq(btn) {
  const item = btn.parentElement;
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

// Hero slideshow
(function() {
  const slides = document.querySelectorAll('.hero-slide');
  const overlay = document.querySelector('.hero-overlay');
  const content = document.querySelector('.hero-content');
  if (slides.length < 2) return;
  let current = 0;
  setInterval(() => {
    slides[current].classList.remove('active');
    current = (current + 1) % slides.length;
    slides[current].classList.add('active');
    if (slides[current].classList.contains('full-bleed')) {
      overlay.style.display = 'none';
      content.style.display = 'none';
    } else {
      overlay.style.display = '';
      content.style.display = '';
    }
  }, 3000);
})();

// Mobile carousel one-at-a-time
(function() {
  const track = document.getElementById('featuredCarousel');
  if (!track || window.innerWidth >= 768) return;
  const cards = track.querySelectorAll('.carousel-card');
  if (cards.length < 2) return;
  const dotsContainer = document.getElementById('carouselDots');
  let current = 0;
  let autoScroll;

  cards.forEach((_, i) => {
    const dot = document.createElement('span');
    if (i === 0) dot.className = 'active';
    dot.onclick = () => goTo(i);
    dotsContainer.appendChild(dot);
  });

  function goTo(i) {
    current = Math.max(0, Math.min(i, cards.length - 1));
    cards[current].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    dotsContainer.querySelectorAll('span').forEach((d, idx) => d.className = idx === current ? 'active' : '');
  }

  function moveSlide(dir) {
    goTo(current + dir);
    resetAuto();
  }

  function resetAuto() {
    clearInterval(autoScroll);
    autoScroll = setInterval(() => goTo((current + 1) % cards.length), 2000);
  }

  track.addEventListener('scroll', () => {
    const idx = Math.round(track.scrollLeft / track.clientWidth);
    if (idx !== current) { current = idx; resetAuto(); }
  });

  resetAuto();
  window.moveSlide = moveSlide;
})();
</script>

