<%- include('partials/header') %>

<section class="hero">
  <div class="hero-slideshow">
    <img class="hero-slide active" src="/uploads/hero-4.png" alt="Cool Cruze - Premium AC rental services banner">
    <img class="hero-slide" src="/uploads/hero-3.png" alt="Tower AC units available for rent from Cool Cruze">
    <img class="hero-slide" src="/uploads/hero-2.png" alt="Tower AC units available for rent from Cool Cruze">
    <img class="hero-slide" src="/uploads/hero-1.png" alt="Portable and split AC rental options from Cool Cruze">
  </div>

</section>


<div class="carousel-section">
  <div class="carousel-container">
    <h2 class="carousel-heading">Rental Products</h2>
    <div class="carousel-viewport">
      <div class="carousel-track" id="carouselTrack">
        <% products.forEach(function(p) { %>
        <div class="carousel-item">
          <div class="carousel-card">
            <% const img = p.carousel_image || p.card_image || (p.images && p.images.length ? p.images[0] : ''); %>
            <div class="carousel-img">
              <% if (img) { %><img src="<%= img %>" alt="<%= p.name %>" class="carousel-img-tag"><% } else { %>❄<% } %>
            </div>
            <div class="carousel-body">
              <div class="carousel-brand"><%= p.brand || 'Premium AC' %></div>
              <div class="carousel-name"><%= p.name %></div>
              <div class="carousel-tags">
                <span><%= p.type %></span>
                <span><%= p.capacity %></span>
              </div>
              <div class="carousel-price">₹<%= Number(p.monthly_price).toLocaleString() %> <span>/day</span></div>
              <div class="carousel-actions">
                <a href="/product/<%= p.id %>" class="carousel-rent-btn">Rent Now</a>
                <a href="/product/<%= p.id %>" class="carousel-details-btn">Details</a>
              </div>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
    <button class="carousel-arrow carousel-prev" onclick="prevSlide()" aria-label="Previous">‹</button>
    <button class="carousel-arrow carousel-next" onclick="nextSlide()" aria-label="Next">›</button>
    <div class="carousel-dots" id="carouselDots"></div>
  </div>
</div>

<section class="section">
  <div class="section-title">
    <h2>Why Mumbai Chooses Cool Cruze for Commercial Cooling</h2>
    <div class="accent-line"></div>
    <p>We make AC rental hassle-free with premium service and support</p>
  </div>
  <div class="benefits-grid-2col">
    <div class="benefit-card-square">
      <div class="benefit-icon">💰</div>
      <h3>Zero Deposit</h3>
