/* Featured Carousel - manual scroll */
.fc-wrap {
  position: relative;
  display: flex;
  align-items: center;
  gap: 8px;
}
.fc-viewport {
  overflow: hidden;
  flex: 1;
}
.fc-track {
  display: flex;
  gap: 24px;
  transition: transform 0.4s ease;
}
.fc-card {
  width: 100px;
  height: 320px;
  flex-shrink: 0;
  background: var(--white);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  display: flex;
  flex-direction: column;
  transition: transform 0.3s, box-shadow 0.3s;
}
.fc-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}
.fc-img {
  width: 100%;
  height: 175px;
  flex-shrink: 0;
  background-size: cover;
  background-position: center;
  background-color: #e2e8f0;
}
.fc-body {
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 5px;
  flex: 1;
}
.fc-brand { font-size: 11px; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.5px; }
.fc-name { font-size: 15px; font-weight: 700; }
.fc-specs { display: flex; gap: 8px; }
.fc-specs span { font-size: 12px; color: var(--text-light); background: #f1f5f9; padding: 2px 8px; border-radius: 4px; }
.fc-price { font-size: 20px; font-weight: 700; color: var(--primary); }
.fc-price span { font-size: 13px; font-weight: 400; color: var(--text-light); }
.fc-actions { display: flex; gap: 8px; margin-top: auto; }
.fc-actions .btn-rent { padding: 8px 16px; font-size: 13px; }
.fc-actions .btn-details { padding: 8px 14px; font-size: 12px; }
.fc-btn {
  width: 40px; height: 40px; border-radius: 50%; border: none;
  background: var(--white); box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  font-size: 24px; cursor: pointer; color: var(--primary);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: background 0.2s;
}
.fc-btn:hover { background: var(--primary); color: var(--white); }
.fc-dots { display: none; }

@media (max-width: 767px) {
  .fc-btn { width: 32px; height: 32px; font-size: 20px; }
  .fc-card { width: 100%; min-width: 0; }
  .fc-actions .btn-rent { padding: 8px 12px; font-size: 12px; }
  .fc-actions .btn-details { padding: 8px 12px; font-size: 12px; }
  .fc-body { padding: 12px 14px; }
