<%- include('partials/header') %>

<section class="hero">
  <div class="hero-slideshow">
    <img class="hero-slide active" src="/uploads/hero.png" alt="Hero">
    <img class="hero-slide" src="/uploads/hero-1.png" alt="Hero 1">
    <img class="hero-slide" src="/uploads/hero-2.png" alt="Hero 2">
    <img class="hero-slide full-bleed" src="/uploads/hero-3.png" alt="Hero 3">
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <h1>Stay Cool with Cool Cruze</h1>
    <p>Premium Tower AC Rentals  Affordable, Reliable, and Delivered to your Doorstep.</p>
    <div class="hero-buttons">
      <a href="/products" class="btn btn-primary">Browse Products</a>
      <a href="/about" class="btn btn-outline">Learn More</a>
    </div>
  </div>
</section>
<% if (featured && featured.length > 0) { %>
<section class="section">
  <div class="section-title">
    <h2>Featured Products</h2>
    <div class="accent-line"></div>
    <p>Our most popular AC units available for rent</p>
  </div>
  <div class="fc-wrap">
    <button class="fc-btn fc-prev" id="fcPrev">‹</button>
    <div class="fc-viewport">
      <div class="fc-track" id="fcTrack">
        <% featured.forEach(product => { %>
        <div class="fc-card">
          <div class="fc-img" style="background-image:url(<%= product.card_image || (product.images && product.images.length ? product.images[0] : '') %>)"></div>
          <div class="fc-body">
            <div class="fc-brand"><%= product.brand %></div>
            <div class="fc-name"><%= product.name %></div>
            <div class="fc-specs">
              <span><%= product.capacity %></span>
              <span><%= product.type %></span>
            </div>
            <div class="fc-price">₹<%= Number(product.monthly_price).toLocaleString() %> <span>/day</span></div>
            <div class="fc-actions">
              <button onclick="openRentModal(<%= product.id %>, '<%= product.name.replace(/'/g, "\\'") %>', '<%= product.brand.replace(/'/g, "\\'") %>', '<%= product.capacity %>', <%= product.monthly_price %>)" class="btn-rent">Rent Now</button>
              <a href="/product/<%= product.id %>" class="btn-details">Details</a>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <button class="fc-btn fc-next" id="fcNext">›</button>
    <div class="fc-dots" id="fcDots"></div>
  </div>
</section>
<% } %>

