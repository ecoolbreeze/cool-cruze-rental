<script>
function toggleFaq(btn) {
  const item = btn.parentElement;
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

// Featured carousel
var track = document.getElementById('carouselTrack');
var dots = document.getElementById('carouselDots');
var carouselIdx = 0; // page index
var total = 0; // total items
var items = [];
var itemWidth = 0;
var visibleCount = 1;
var pages = 1;

function getVisibleCount(){
  var w = window.innerWidth;
  if(w >= 1200) return 4;
  if(w >= 900) return 3;
  if(w >= 600) return 2;
  return 1;
}

function updateDots(){
  if(!dots) return;
  dots.innerHTML = '';
  pages = Math.max(1, Math.ceil(total / visibleCount));
  for(var i=0;i<pages;i++){
    var dot = document.createElement('button');
    dot.className = 'carousel-dot' + (i===carouselIdx?' active':'');
    dot.setAttribute('aria-label','Page '+(i+1));
    dot.onclick = (function(n){return function(){goTo(n);};})(i);
    dots.appendChild(dot);
  }
}

function initCarousel(){
  if(!track) return;
  items = track.querySelectorAll('.carousel-item');
  total = items.length;
  visibleCount = getVisibleCount();
  updateDots();
  recalcWidth();
  goTo(0);
}

function recalcWidth(){
  itemWidth = (items && items.length) ? items[0].getBoundingClientRect().width : 0;
}

function goTo(page){
  pages = Math.max(1, Math.ceil(total / visibleCount));
  carouselIdx = Math.max(0, Math.min(page, pages - 1));
  recalcWidth();
  if(itemWidth){
    var offset = carouselIdx * (itemWidth * visibleCount);
    track.style.transform = 'translateX(-' + offset + 'px)';
  } else {
    track.style.transform = 'translateX(-' + (carouselIdx * 100) + '%)';
  }
  var allDots = dots ? dots.querySelectorAll('.carousel-dot') : [];
  allDots.forEach(function(d,i){d.classList.toggle('active',i===carouselIdx);});
}

function prevSlide(){ goTo(carouselIdx - 1 < 0 ? pages - 1 : carouselIdx - 1); }
function nextSlide(){ goTo(carouselIdx + 1 >= pages ? 0 : carouselIdx + 1); }

window.addEventListener('resize', function(){
  items = track ? track.querySelectorAll('.carousel-item') : [];
  total = items.length;
  visibleCount = getVisibleCount();
  updateDots();
  recalcWidth();
  goTo(Math.min(carouselIdx, Math.max(0, pages - 1)));
});

initCarousel();

// Hero slideshow
(function() {
  const slides = document.querySelectorAll('.hero-slide');
  if (slides.length < 2) return;
  let current = 0;
  setInterval(() => {
    slides[current].classList.remove('active');
    current = (current + 1) % slides.length;
    slides[current].classList.add('active');
  }, 3000);
})();

</script>

