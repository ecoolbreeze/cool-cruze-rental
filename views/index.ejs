  }
  .fc-dots span {
    width: 8px; height: 8px; border-radius: 50%;
    background: #cbd5e1; cursor: pointer; transition: background 0.3s;
  }
  .fc-dots span.active { background: var(--primary); }
}
</style>

<script>
function toggleFaq(btn) {
  const item = btn.parentElement;
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

// Hero slideshow
(function() {
  const slides = document.querySelectorAll('.hero-slide');
  const overlay = document.querySelector('.hero-overlay');
  const content = document.querySelector('.hero-content');
  if (slides.length < 2) return;
  let current = 0;
  setInterval(() => {
    slides[current].classList.remove('active');
    current = (current + 1) % slides.length;
    slides[current].classList.add('active');
    if (slides[current].classList.contains('full-bleed')) {
      overlay.style.display = 'none';
      content.style.display = 'none';
    } else {
      overlay.style.display = '';
      content.style.display = '';
    }
  }, 3000);
})();

// Featured carousel - manual scroll
(function() {
  var track = document.getElementById('fcTrack');
  var prev = document.getElementById('fcPrev');
  var next = document.getElementById('fcNext');
  var dots = document.getElementById('fcDots');
  if (!track) return;
  var cards = track.querySelectorAll('.fc-card');
  if (!cards.length) return;
  var current = 0;

  function getCardWidth() {
    return cards[0].getBoundingClientRect().width + 24;
  }

  function goTo(idx) {
    var total = cards.length;
    var viewW = track.parentElement.clientWidth;
    var visible = Math.max(1, Math.floor(viewW / getCardWidth()));
    var max = Math.max(0, total - visible);
    current = Math.max(0, Math.min(idx, max));
    track.style.transform = 'translateX(-' + (current * getCardWidth()) + 'px)';
    if (dots) {
      var spans = dots.querySelectorAll('span');
      for (var i = 0; i < spans.length; i++) {
        spans[i].className = i === current ? 'active' : '';
      }
    }
  }

  function onResize() {
    var vw = window.innerWidth;
    if (vw >= 768) {
      if (dots) dots.style.display = 'none';
    } else {
      if (dots) dots.style.display = 'flex';
    }
    goTo(current);
  }

  prev.addEventListener('click', function() { goTo(current - 1); });
  next.addEventListener('click', function() { goTo(current + 1); });

  if (dots) {
    for (var i = 0; i < cards.length; i++) {
      var d = document.createElement('span');
      if (i === 0) d.className = 'active';
      d.onclick = (function(idx) { return function() { goTo(idx); }; })(i);
      dots.appendChild(d);
    }
  }

  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(onResize, 150);
  });
  onResize();
})();

</script>

