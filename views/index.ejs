}

.step-icon {
  font-size: 36px;
  margin-bottom: 10px;
}

.step-card-square h3 {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 6px;
}

.step-card-square p {
  color: var(--text-light);
  font-size: 13px;
  max-width: 200px;
}

.step-connector {
  font-size: 32px;
  color: var(--primary-light);
  font-weight: 700;
  padding: 0 8px;
