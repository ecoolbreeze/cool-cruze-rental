<%- include('partials/header') %>

<section class="section">
  <div class="section-title">
    <h2>Our AC Collection</h2>
    <div class="accent-line"></div>
    <p>Premium air conditioners for rent — choose your perfect match</p>
  </div>

  <div class="filters">
    <input type="text" id="search" placeholder="Search products..." onkeyup="filterProducts()">
    <select id="filterType" onchange="filterProducts()">
      <option value="">All Types</option>
      <option value="Split">Split AC</option>
      <option value="Window">Window AC</option>
      <option value="Tower">Tower AC</option>
      <option value="Cassette">Cassette AC</option>
    </select>
    <select id="filterCapacity" onchange="filterProducts()">
      <option value="">All Capacity</option>
      <option value="1 Ton">1 Ton</option>
      <option value="1.5 Ton">1.5 Ton</option>
      <option value="2 Ton">2 Ton</option>
      <option value="2.5 Ton">2.5 Ton</option>
      <option value="3 Ton">3 Ton</option>
    </select>
  </div>

  <div class="products-grid" id="productGrid">
    <% if (products.length === 0) { %>
      <div style="grid-column: 1/-1; text-align: center; padding: 60px; color: var(--text-light);">
        <div style="font-size: 48px; margin-bottom: 16px;">❄️</div>
        <h3>No products yet</h3>
        <p>Check back soon! We're adding new ACs regularly.</p>
      </div>
    <% } %>
    <% products.forEach(product => { %>
    <div class="product-card" data-name="<%= product.name.toLowerCase() %>" data-type="<%= product.type %>" data-capacity="<%= product.capacity %>">
      <% const img = product.images && product.images.length ? product.images[0] : product.image; %>
      <div class="product-img" style="<%= img ? 'background-image:url('+img+');background-size:cover;background-position:center' : '' %>">
        <% if (!img) { %>❄️<% } %>
      </div>
      <div class="product-body">
        <div class="product-brand"><%= product.brand %></div>
        <div class="product-name"><%= product.name %></div>
        <div class="product-specs">
          <span class="product-spec"><%= product.capacity %></span>
          <span class="product-spec"><%= product.type %></span>
        </div>
        <div class="product-price">₹<%= Number(product.monthly_price).toLocaleString() %> <span>/month</span></div>
        <div class="product-desc"><%= product.description ? product.description.substring(0, 100) + (product.description.length > 100 ? '...' : '') : 'Premium quality AC available for rent. Contact us for more details.' %></div>
        <div class="product-actions">
          <button onclick="openRentModal(<%= product.id %>, '<%= product.name.replace(/'/g, "\\'") %>', '<%= product.brand.replace(/'/g, "\\'") %>', '<%= product.capacity %>', <%= product.monthly_price %>)" class="btn-rent">Rent Now</button>
          <a href="/product/<%= product.id %>" class="btn-details">Details</a>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</section>

<script>
function filterProducts() {
  const search = document.getElementById('search').value.toLowerCase();
  const type = document.getElementById('filterType').value;
  const capacity = document.getElementById('filterCapacity').value;
  document.querySelectorAll('.product-card').forEach(card => {
    const name = card.dataset.name;
    const cardType = card.dataset.type;
    const cardCapacity = card.dataset.capacity;
    const matchSearch = !search || name.includes(search);
    const matchType = !type || cardType === type;
    const matchCapacity = !capacity || cardCapacity === capacity;
    card.style.display = (matchSearch && matchType && matchCapacity) ? '' : 'none';
  });
}
</script>

<%- include('partials/footer') %>
